generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Group {
  id             Int                    @id @default(autoincrement())
  name           String                 @unique @db.VarChar(50)
  abbreviatedName String?               @map("abbreviated_name") @db.VarChar(10)
  employeeGroups EmployeeGroup[]
  groupHistory   EmployeeGroupHistory[]

  @@map("groups")
}

// CSVインポート等の実施記録（1インポート=1行のサマリ）。
// 変更履歴(shift_change_history)とは別物: こちらは「いつ・誰が・何件取り込んだか」の事実記録。
// 履歴トリガーは付与しない（追記専用）。targetType でデータ種別を区別し、将来の他インポートも相乗り可能。
model ImportLog {
  id           Int      @id @default(autoincrement())
  targetType   String   @map("target_type") @db.VarChar(30) // 'shifts' | 'employees' | 'roles' | 'dutyTypes' | 'dutyAssignments' | 'shiftCodes'
  fileName     String?  @map("file_name") @db.VarChar(255)
  createdCount Int      @default(0) @map("created_count")
  updatedCount Int      @default(0) @map("updated_count")
  errorCount   Int      @default(0) @map("error_count")
  importedBy   String?  @map("imported_by") @db.VarChar(100)
  importedAt   DateTime @default(now()) @map("imported_at")

  @@index([targetType, importedAt])
  @@map("import_log")
}

model Employee {
  id              String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  name            String    @db.VarChar(100)
  nameKana        String?   @map("name_kana") @db.VarChar(100)
  hireDate        DateTime? @map("hire_date") @db.Date
  terminationDate DateTime? @map("termination_date") @db.Date

  groups           EmployeeGroup[]
  shifts           Shift[]
  functionRoles    EmployeeFunctionRole[]
  positions        EmployeePosition[]
  externalAccounts EmployeeExternalAccount[]
  groupHistory     EmployeeGroupHistory[]
  roleHistory      EmployeeFunctionRoleHistory[]
  positionHistory    EmployeePositionHistory[]
  shiftChangeHistory ShiftChangeHistory[]
  dutyAssignments       DutyAssignment[]
  skills                EmployeeSkill[]

  @@map("employees")
}

model Shift {
  id               Int       @id @default(autoincrement())
  employeeId       String?   @map("employee_id") @db.Uuid
  shiftDate        DateTime  @map("shift_date") @db.Date
  shiftCode        String?   @map("shift_code") @db.VarChar(20)
  startTime        DateTime? @map("start_time") @db.Time(6)
  endTime          DateTime? @map("end_time") @db.Time(6)
  isHoliday        Boolean?  @default(false) @map("is_holiday")
  isRemote         Boolean   @default(false) @map("is_remote")
  lunchBreakStart  DateTime? @map("lunch_break_start") @db.Time(6)
  lunchBreakEnd    DateTime? @map("lunch_break_end") @db.Time(6)

  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, shiftDate])
  @@map("shifts")
}

enum FunctionRoleKind {
  SUPERVISOR
  BUSINESS
  OTHER

  @@map("function_role_kind")
}

model FunctionRole {
  id       Int              @id @default(autoincrement())
  roleCode String           @unique @map("role_code") @db.VarChar(20)
  roleName String           @map("role_name") @db.VarChar(50)
  roleType String           @default("FUNCTION") @map("role_type") @db.VarChar(20)
  kind     FunctionRoleKind @default(OTHER)
  isActive Boolean?         @default(true) @map("is_active")

  employeeRoles EmployeeFunctionRole[]

  @@map("function_roles")
}

model EmployeeFunctionRole {
  id             Int              @id @default(autoincrement())
  employeeId     String?          @map("employee_id") @db.Uuid
  functionRoleId Int?             @map("function_role_id")
  roleType       String           @default("FUNCTION") @map("role_type") @db.VarChar(20)
  kind           FunctionRoleKind @default(OTHER)
  isPrimary      Boolean?         @default(false) @map("is_primary")
  startDate      DateTime?        @map("start_date") @db.Date
  endDate        DateTime?        @map("end_date") @db.Date

  employee     Employee?     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  functionRole FunctionRole? @relation(fields: [functionRoleId], references: [id])

  @@index([employeeId, startDate, endDate], map: "employee_function_roles_employee_dates_idx")
  @@map("employee_function_roles")
}

model ShiftChangeHistory {
  id                  Int       @id @default(autoincrement())
  shiftId             Int       @map("shift_id")
  employeeId          String?   @map("employee_id") @db.Uuid
  shiftDate           DateTime  @map("shift_date") @db.Date
  shiftCode           String?   @map("shift_code") @db.VarChar(20)
  startTime           DateTime? @map("start_time") @db.Time(6)
  endTime             DateTime? @map("end_time") @db.Time(6)
  isHoliday           Boolean?  @map("is_holiday")
  isRemote            Boolean?  @map("is_remote")
  lunchBreakStart     DateTime? @map("lunch_break_start") @db.Time(6)
  lunchBreakEnd       DateTime? @map("lunch_break_end") @db.Time(6)
  newShiftCode        String?   @map("new_shift_code") @db.VarChar(20)
  newStartTime        DateTime? @map("new_start_time") @db.Time(6)
  newEndTime          DateTime? @map("new_end_time") @db.Time(6)
  newIsHoliday        Boolean?  @map("new_is_holiday")
  newIsRemote         Boolean?  @map("new_is_remote")
  newLunchBreakStart  DateTime? @map("new_lunch_break_start") @db.Time(6)
  newLunchBreakEnd    DateTime? @map("new_lunch_break_end") @db.Time(6)
  version             Int
  changedAt           DateTime  @default(now()) @map("changed_at")
  note                String?   @db.VarChar(255)

  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([shiftId, version])
  @@index([shiftId, changedAt])
  @@index([employeeId, shiftDate])
  @@map("shift_change_history")
}

model EmployeeGroupHistory {
  id         Int       @id @default(autoincrement())
  employeeId String    @map("employee_id") @db.Uuid
  groupId    Int?      @map("group_id")
  startDate  DateTime? @map("start_date") @db.Date
  endDate    DateTime? @map("end_date") @db.Date
  changeType String    @map("change_type") @db.VarChar(10)
  version    Int
  changedAt  DateTime  @default(now()) @map("changed_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  group    Group?   @relation(fields: [groupId], references: [id], onDelete: Restrict)

  @@unique([employeeId, version])
  @@index([employeeId, changedAt])
  @@map("employee_group_history")
}

model ExternalTool {
  id       Int     @id @default(autoincrement())
  toolCode String  @map("tool_code") @db.VarChar(50)
  toolName String  @map("tool_name") @db.VarChar(100)
  isActive Boolean? @default(true) @map("is_active")

  accounts EmployeeExternalAccount[]

  @@map("external_tools")
}

model EmployeeExternalAccount {
  id             Int     @id @default(autoincrement())
  employeeId     String? @map("employee_id") @db.Uuid
  externalToolId Int?    @map("external_tool_id")
  externalName   String  @map("external_name") @db.VarChar(100)
  externalId     String? @map("external_id") @db.VarChar(100)
  isActive       Boolean? @default(true) @map("is_active")

  employee     Employee?     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  externalTool ExternalTool? @relation(fields: [externalToolId], references: [id])

  @@map("employee_external_accounts")
}

model EmployeeFunctionRoleHistory {
  id             Int               @id @default(autoincrement())
  employeeId     String            @map("employee_id") @db.Uuid
  functionRoleId Int?              @map("function_role_id")
  roleType       String?           @map("role_type") @db.VarChar(20)
  kind           FunctionRoleKind?
  isPrimary      Boolean?          @map("is_primary")
  startDate      DateTime?         @map("start_date") @db.Date
  endDate        DateTime?         @map("end_date") @db.Date
  changeType     String            @map("change_type") @db.VarChar(10)
  version        Int
  changedAt      DateTime          @default(now()) @map("changed_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, version])
  @@index([employeeId, changedAt])
  @@map("employee_function_role_history")
}

model ShiftCode {
  id                       Int       @id @default(autoincrement())
  code                     String    @unique @db.VarChar(20)
  color                    String?   @db.VarChar(20)
  defaultStartTime         DateTime? @map("default_start_time") @db.Time(6)
  defaultEndTime           DateTime? @map("default_end_time") @db.Time(6)
  defaultIsHoliday         Boolean   @default(false) @map("default_is_holiday")
  isActive                 Boolean?  @default(true) @map("is_active")
  sortOrder                Int       @default(0) @map("sort_order")
  defaultLunchBreakStart   DateTime? @map("default_lunch_break_start") @db.Time(6)
  defaultLunchBreakEnd     DateTime? @map("default_lunch_break_end") @db.Time(6)

  @@map("shift_codes")
}

model Position {
  id           Int     @id @default(autoincrement())
  positionCode String  @unique @map("position_code") @db.VarChar(20)
  positionName String  @map("position_name") @db.VarChar(50)
  isActive     Boolean? @default(true) @map("is_active")
  sortOrder    Int     @default(0) @map("sort_order")

  employeePositions EmployeePosition[]

  @@map("positions")
}

model EmployeePosition {
  id         Int       @id @default(autoincrement())
  employeeId String    @map("employee_id") @db.Uuid
  positionId Int       @map("position_id")
  startDate  DateTime? @map("start_date") @db.Date
  endDate    DateTime? @map("end_date") @db.Date

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  position Position @relation(fields: [positionId], references: [id], onDelete: Restrict)

  @@map("employee_positions")
}

model EmployeeGroup {
  id         Int       @id @default(autoincrement())
  employeeId String    @map("employee_id") @db.Uuid
  groupId    Int       @map("group_id")
  startDate  DateTime? @map("start_date") @db.Date
  endDate    DateTime? @map("end_date") @db.Date

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Restrict)

  @@index([employeeId, startDate, endDate], map: "employee_groups_employee_dates_idx")
  @@map("employee_groups")
}

model DutyType {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(50)
  color     String?   @db.VarChar(20)
  isActive         Boolean?  @default(true) @map("is_active")
  sortOrder        Int       @default(0) @map("sort_order")
  defaultReducesCapacity  Boolean   @default(true) @map("default_reduces_capacity")
  defaultStartTime       String?   @map("default_start_time") @db.VarChar(5)
  defaultEndTime         String?   @map("default_end_time") @db.VarChar(5)
  defaultNote            String?   @map("default_note") @db.Text
  defaultTitle           String?   @map("default_title") @db.VarChar(100)

  dutyAssignments       DutyAssignment[]

  @@map("duty_types")
}

model DutyAssignment {
  id         Int      @id @default(autoincrement())
  employeeId String   @map("employee_id") @db.Uuid
  dutyTypeId Int      @map("duty_type_id")
  dutyDate   DateTime @map("duty_date") @db.Date
  startTime  DateTime @map("start_time") @db.Time(6)
  endTime    DateTime @map("end_time") @db.Time(6)
  note              String?  @db.Text
  title             String?  @db.VarChar(100)
  reducesCapacity   Boolean  @default(true) @map("reduces_capacity")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  dutyType DutyType @relation(fields: [dutyTypeId], references: [id], onDelete: Restrict)

  @@unique([employeeId, dutyTypeId, dutyDate, startTime])
  @@map("duty_assignments")
}

// 業務割当の一括置換バッチ（業務種別の統廃合）。実行ごとに1行。
// Undo(取り消し)のため、影響した割当と置換前の業務種別を items に保持する。
// 履歴トリガーは付けない（追記専用の事実記録）。
model DutyAssignmentBulkReplaceBatch {
  id              Int       @id @default(autoincrement())
  fromDutyTypeIds Int[]     @map("from_duty_type_ids")
  toDutyTypeId    Int       @map("to_duty_type_id")
  replacedCount   Int       @map("replaced_count")
  skippedCount    Int       @map("skipped_count")
  executedBy      String?   @map("executed_by") @db.VarChar(100)
  executedAt      DateTime  @default(now()) @map("executed_at")
  revertedBy      String?   @map("reverted_by") @db.VarChar(100)
  revertedAt      DateTime? @map("reverted_at")

  items DutyAssignmentBulkReplaceItem[]

  @@index([executedAt])
  @@map("duty_assignment_bulk_replace_batch")
}

// バッチで置換した1割当の記録（置換前の業務種別）。
// dutyAssignmentId はあえて FK を張らない（割当が後で削除/カスケード消失しても
// 監査記録は残す。Undo は実行時にガードで対応する）。
model DutyAssignmentBulkReplaceItem {
  id                 Int @id @default(autoincrement())
  batchId            Int @map("batch_id")
  dutyAssignmentId   Int @map("duty_assignment_id")
  previousDutyTypeId Int @map("previous_duty_type_id")

  batch DutyAssignmentBulkReplaceBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@map("duty_assignment_bulk_replace_item")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique @db.VarChar(50)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model EmployeePositionHistory {
  id         Int       @id @default(autoincrement())
  employeeId String    @map("employee_id") @db.Uuid
  positionId Int?      @map("position_id")
  startDate  DateTime? @map("start_date") @db.Date
  endDate    DateTime? @map("end_date") @db.Date
  changeType String    @map("change_type") @db.VarChar(10)
  version    Int
  changedAt  DateTime  @default(now()) @map("changed_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, version])
  @@index([employeeId, changedAt])
  @@map("employee_position_history")
}

// スキルマスタ。positions とほぼ同型。
model Skill {
  id        Int      @id @default(autoincrement())
  skillCode String   @unique @map("skill_code") @db.VarChar(20)
  skillName String   @map("skill_name") @db.VarChar(50)
  isActive  Boolean? @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")

  employeeSkills EmployeeSkill[]

  @@map("skills")
}

// スキル割当（追記専用ログ＝履歴そのもの）。
// 1行 = (社員, スキル, レベル, 付与日)。レベルアップは新規行の追記で表現し、
// 過去行は書き換えない。各 (社員, スキル) の最新行（start_date 降順→id 降順）が
// 現在のレベル。end_date は持たず、訂正は物理 DELETE で行う。
// 別履歴テーブル・トリガーは持たない（duty_assignments と同じ追記専用思想）。
// 「現在のレベル一覧」は employee_current_skills ビュー経由で取得する。
model EmployeeSkill {
  id         Int      @id @default(autoincrement())
  employeeId String   @map("employee_id") @db.Uuid
  skillId    Int      @map("skill_id")
  level      Int // 1..5（アプリ側 Zod でバリデーション）
  startDate  DateTime @map("start_date") @db.Date
  createdAt  DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  skill    Skill    @relation(fields: [skillId], references: [id], onDelete: Restrict)

  @@index([employeeId, skillId, startDate], map: "employee_skills_employee_skill_date_idx")
  @@map("employee_skills")
}
